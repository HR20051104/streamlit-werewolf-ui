# Core game settings
TOTAL_PLAYERS=7
DISCUSSION_ROUNDS=1
MAX_ROUNDS=20
STEP_BY_STEP=true

# AI output limits
AI_STATEMENT_MAX_CHARS=160
AI_LAST_WORDS_MAX_CHARS=120

# Role / testing toggles
ENABLE_GUARD=true
FORCE_HUMAN_WEREWOLF=false
HUMAN_ROLE=random

# Vote rules
REVOTE_ON_TIE=true
REVOTE_DISCUSSION_ROUNDS=1
FINAL_TIE_POLICY=no_elimination

# Narration / debug
NARRATION_STYLE=standard
DEBUG=false

# LLM settings
USE_LLM=false
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
